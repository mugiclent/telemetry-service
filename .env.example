NODE_ENV=development
PORT=8093

# Docker image (used by docker-compose.yml)
DOCKER_USERNAME=ktshonln
IMAGE_TAG=latest

# Redis — password only; host/port default to redis:6379
REDIS_PASSWORD=
# REDIS_HOST=redis   (default)
# REDIS_PORT=6379    (default)

# RabbitMQ — credentials only; host/port default to rabbitmq:5672
RABBITMQ_USER=
RABBITMQ_PASSWORD=
# RABBITMQ_HOST=rabbitmq  (default)
# RABBITMQ_PORT=5672      (default)

# How long a bus's latest fix lives before it's considered stale (seconds).
# LATEST_TTL_SECONDS=300
# Safety-net expiry for the device→trip mapping if a trip-end event is missed (seconds).
# MAPPING_TTL_SECONDS=86400
